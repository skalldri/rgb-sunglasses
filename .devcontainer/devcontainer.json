{
    "name": "RGB Sunglasses Dev Container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "nordic-semiconductor.nrf-connect-extension-pack",
                "ms-vscode.live-server",
                "cschlosser.doxdocgen",
                "expo.vscode-expo-tools",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "Anthropic.claude-code",
                "ms-vscode.vscode-websearchforcopilot"
            ]
        }
    },
    "containerEnv": {
        "ACCEPT_JLINK_LICENSE": "1",
        // Point Claude Code's config root at the persisted volume mounted below (see "mounts").
        // This consolidates ALL of Claude Code's state under one directory — credentials, session
        // transcripts, settings, history, AND the top-level .claude.json config — so a single
        // named volume survives container rebuilds. (Verified: setting CLAUDE_CONFIG_DIR relocates
        // .claude.json into this dir, so no fragile symlink of that file is needed.)
        "CLAUDE_CONFIG_DIR": "/root/.claude"
    },
    "runArgs": [
        "--privileged",
        "--network=host"
    ],
    // Persist Claude Code login + conversation history + config across container rebuilds.
    // The container's /root is discarded on rebuild; this named Docker volume is not, so the
    // CLI stays logged in and past sessions remain. Only the mount CONFIG lives here — the
    // actual token/history/config data lives solely in the local `rgb-sunglasses-claude`
    // Docker volume on your machine and is never committed. Empty on first rebuild (log in
    // once); persists forever after. Paired with CLAUDE_CONFIG_DIR above.
    "mounts": [
        "source=rgb-sunglasses-claude,target=/root/.claude,type=volume"
    ],
    // Runs before the container starts. With Docker Desktop + "Clone in Container Volume",
    // this executes inside docker-desktop WSL2 (not on the Windows host), so we use a
    // shell script instead of PowerShell. docker-desktop is the WSL2 kernel host, so
    // modprobe works there directly. usbipd is attempted via Windows interop (best-effort).
    // See .devcontainer/USB.md for the one-time `usbipd bind` step.
    "initializeCommand": "/bin/sh .devcontainer/scripts/host-usb-init.sh",
    "forwardPorts": [
        8081
    ],
    // Diagnostic only: report whether the device's serial ports showed up in the container.
    "postStartCommand": "bash -lc 'if ls /dev/ttyACM* >/dev/null 2>&1; then echo \"[usb] CDC-ACM ports: $(ls /dev/ttyACM*)\"; else echo \"[usb] No /dev/ttyACM* yet. Device: $(lsusb | grep -i 2fe3 || echo not-detected). If plugged in, make sure you ran the one-time \\\"usbipd bind\\\" - see .devcontainer/USB.md.\"; fi'",
    "postCreateCommand": {
        "jlink": "dpkg -i /jlink/JLink_Linux.deb",
        "python": "pip install lz4 yaspin tqdm Pillow serial-mcp-server yt-dlp",
        "app": "cd /workspaces/rgb-sunglasses/app && npm install",
        "claude": "npm install -g @anthropic-ai/claude-code",
        "android-ndk": "[ -n \"$CI\" ] || sdkmanager --install \"ndk;27.1.12297006\" \"cmake;3.22.1\"",
        "adb-wireless": "[ -n \"$CI\" ] || cargo install --jobs 1 adb-wireless"
    }
}
