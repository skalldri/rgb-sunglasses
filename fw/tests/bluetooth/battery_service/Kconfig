source "Kconfig.zephyr"

config APP_PERSIST_BT_CONFIG
	bool "Persist BT-settable configuration via the Settings subsystem"
	default y
	help
	  Mirrors the symbol of the same name in fw/Kconfig - this test compiles
	  battery_service.cpp and the persistent-value sources directly, outside
	  the main fw application's Kconfig tree, so it needs its own definition
	  to compile in the real persistence paths.

config APP_PERSIST_WORKQ_STACK_SIZE
	int "Stack size for the persistent-value-store workqueue"
	default 2048
	depends on APP_PERSIST_BT_CONFIG
	help
	  Mirrors the symbol of the same name in fw/Kconfig.

config APP_SETTINGS_SAVE_DEBOUNCE_MS
	int "Debounce interval (ms) before persisting a changed config value"
	default 1000
	depends on SETTINGS
	help
	  Mirrors the symbol of the same name in fw/Kconfig.
