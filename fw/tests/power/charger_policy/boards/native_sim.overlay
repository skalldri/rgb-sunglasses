/*
 * Instantiate the TPS25750 on native_sim's emulated I2C controller (i2c0 is
 * a zephyr,i2c-emul-controller) so the real driver initializes against the
 * out-of-tree emulator (fw/drivers/emul_tps25750), and the real BQ25792
 * driver — a child of the tps25750 node, exactly like proto0's DTS — runs
 * on top of the real I2Cm bridge.
 *
 * No irq-gpios on either node: both drivers treat the interrupt pin as
 * optional, and nothing in this suite exercises the IRQ paths.
 */

&i2c0 {
	tps25750: tps25750@21 {
		compatible = "ti,tps25750";
		reg = <0x21>;
		patch-address = <0x15>;
		patch-chunk-size = <128>;
		status = "okay";

		/* TPS25750 is also an I2C master. Define required properties */
		#address-cells = <1>;
		#size-cells = <0>;

		bq25792: bq25792@6b {
			compatible = "ti,bq25792";
			reg = <0x6B>;
			status = "okay";
		};
	};
};
