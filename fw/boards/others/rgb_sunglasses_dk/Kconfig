if BOARD_RGB_SUNGLASSES_DK_NRF5340_CPUAPP || BOARD_RGB_SUNGLASSES_DK_NRF5340_CPUAPP_NS

config BOARD_ENABLE_UICR_ACCESS
	bool "Enable application writes to the UICR flash"
	select SOC_FLASH_NRF_UICR
	default y

# Powering up the network core at boot is handled by the SoC-level
# SOC_NRF53_CPUNET_ENABLE symbol (see Kconfig.defconfig, which defaults it on
# when BT is enabled). The board-level BOARD_ENABLE_CPUNET symbol this file
# used to define is deprecated upstream (zephyr/soc/nordic/nrf53/Kconfig) and
# its cpunet_reset.c has been removed with it (issue #164): the SoC-level
# bring-up (nrf53_cpunet_mgmt.c) performs the same SPU secure retention, GPIO
# forwarding, and FORCEOFF release this project relied on. (cpunet_reset.c
# also had a BT_CTLR_DEBUG_PINS_CPUAPP debug-pin hook, but that symbol
# depends on the upstream nRF5340DK board and was unreachable here.)

endif #  BOARD_RGB_SUNGLASSES_DK_NRF5340_CPUAPP || BOARD_RGB_SUNGLASSES_DK_NRF5340_CPUAPP_NS
