#include "rgb_sunglasses_proto0_nrf5340_cpuapp_common-pinctrl.dtsi"

#include <freq.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/spi/spi.h>

/ {

	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
		zephyr,uart-mcumgr = &cdc_acm_uart1;
		//zephyr,bt-mon-uart = &uart0; // @skalldri what does this do?
		//zephyr,bt-c2h-uart = &uart0; // @skalldri what does this do?
		zephyr,bt-hci = &bt_hci_ipc0;
		nordic,802154-spinel-ipc = &ipc0;
		zephyr,ieee802154 = &ieee802154;
		nordic,pm-ext-flash = &mx25r64;
		/* Do NOT add zephyr,settings-partition here. NCS replaces flash_map_default.c with
		 * flash_map_partition_manager.c (PM IDs, not DTS IDs). flash_map_pm.h redefines
		 * FIXED_PARTITION_ID(storage_partition) → PM_SETTINGS_STORAGE_ID = 9, so
		 * settings_nvs.c's fallback path already routes to the correct external flash region
		 * at 0x11c000. Adding zephyr,settings-partition would switch to DT_FIXED_PARTITION_ID
		 * which collides with PM IDs and opens the wrong partition. */
	};

	/*leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;
			label = "Green LED 0";
		};
		led1: led_1 {
			gpios = <&gpio0 29 GPIO_ACTIVE_LOW>;
			label = "Green LED 1";
		};
		led2: led_2 {
			gpios = <&gpio0 30 GPIO_ACTIVE_LOW>;
			label = "Green LED 2";
		};
		led3: led_3 {
			gpios = <&gpio0 31 GPIO_ACTIVE_LOW>;
			label = "Green LED 3";
		};
	};*/

	/*pwmleds {
		compatible = "pwm-leds";
		pwm_led0: pwm_led_0 {
			pwms = <&pwm0 0 PWM_MSEC(20) PWM_POLARITY_INVERTED>;
		};
	};*/

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio1 10 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 1 (Up)";
		};
		button1: button_1 {
			gpios = <&gpio1 11 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 2 (Left)";
		};
		button2: button_2 {
			gpios = <&gpio0 30 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 3 (Right)";
		};
		button3: button_3 {
			gpios = <&gpio1 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button 4 (Down)";
		};
		button4: bmic_wake {
			gpios = <&gpio0 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "BMIC Wake";
		};
	};

	gpio_fwd: nrf-gpio-forwarder {
		compatible = "nordic,nrf-gpio-forwarder";
		status = "okay";
		uart {
			gpios = <&gpio1 13 0>, <&gpio1 14 0>;
		};
	};

	/* These aliases are provided for compatibility with samples */
	aliases {
		/*led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
		pwm-led0 = &pwm_led0;*/
		sw0 = &button0;
		sw1 = &button1;
		sw2 = &button2;
		sw3 = &button3;
		sw-wake = &button4;
		/*bootloader-led0 = &led0;*/
		mcuboot-button0 = &button1;
		/*mcuboot-led0 = &led0;*/
		watchdog0 = &wdt0;
		led-strip-0 = &led_strip_0;
		led-strip-1 = &led_strip_1;
		led-strip-2 = &led_strip_2;
		spi-flash0 = &mx25r64;
		mic = &pdm0;
	};
};

/* configure VREGMAIN in DC/DC mode */
&vregmain {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

/* configure VREGRADIO in DC/DC mode */
&vregradio {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

/* mistake in the devkit. Didn't populate DCCH. Cannot use DCDC mode for the HV regulator */
&vregh {
	status = "disabled";
};

&adc {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";

	tps25750: tps25750@21 {
		compatible = "ti,tps25750";
		reg = <0x21>; /* The address of the device in "normal" mode */
		patch-address = <0x15>; /* The address of the device during patch download */
		patch-chunk-size = <128>; /* the size of the packets sent during patch download */
		status = "okay";
		irq-gpios = <&gpio0 22 (GPIO_ACTIVE_LOW)>; /* Might need to add GPIO_PULL_UP or GPIO_PULL_DOWN here? */

		/* TPS25750 is also an I2C master. Define required properties */
		#address-cells = <1>;
		#size-cells = <0>;

		bq25792: bq25792@6b {
			compatible = "ti,bq25792";
			reg = <0x6B>;
			/* P1.04 = BQ25792 interrupt (active low) */
			irq-gpios = <&gpio1 4 (GPIO_ACTIVE_LOW)>;
			status = "okay";
		};
	};
};

&clock {
	hfclkaudio-frequency = <12288000>;
};

&pdm0 {
	status = "okay";
	pinctrl-0 = <&pdm0_default>;
	pinctrl-names = "default";
	/* Verified against real beat/fft_bars audio load (issue #75, k_mem_slab_max_used_get()):
	 * peak in-flight blocks stayed at 3 out of the previous 32+1 budget. 8 leaves ~2.6x margin. */
	queue-size = <8>;
	clock-source = "PCLK32M";
};

/* uart0 shares the hardware instance with i2c0 (TWIM0) on nRF5340 — cannot enable both.
 * The physical UART pins (P1.13=TX, P1.14=RX) are defined in pinctrl for future use,
 * but the peripheral is disabled here. Primary console is USB CDC ACM. */
&uart0 {
	//status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&timer0 {
	status = "okay";
};

&timer1 {
	status = "okay";
};

&timer2 {
	status = "okay";
};

/* BMI270 6-axis IMU: P0.09=MOSI, P0.10=MISO, P0.12=SCK, P0.24=CS, P0.26=INT1, P0.25=INT2
 * Uses SPI3 (SPIM3): SPI0/SPIM0 shares the same hardware instance as I2C0/TWIM0 on nRF5340. */
&spi3 {
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 24 GPIO_ACTIVE_LOW>;

	bmi270: bmi270@0 {
		compatible = "bosch,bmi270";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(10)>;
		/* P0.26 = INT1, P0.25 = INT2 */
		irq-gpios = <&gpio0 26 GPIO_ACTIVE_HIGH>,
			    <&gpio0 25 GPIO_ACTIVE_HIGH>;
	};
};

led_strip_spi_0: &spi1 {
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";

	// Attach our LED strip to SPI1
	led_strip_0: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		status = "okay";

		/* SPI */
		reg = <0>; /* ignored, but necessary for SPI bindings */
		spi-max-frequency = <DT_FREQ_M(4)>;
		frame-format = <SPI_FRAME_FORMAT_TI>;

		/* WS2812 */
		chain-length = <216>; /* arbitrary; change at will */
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
	};
};

/* Onboard status LEDs: 2x WS2812 on P1.01 */
led_strip_spi_2: &spi2 {
	status = "okay";
	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";

	led_strip_2: ws2812_2@0 {
		compatible = "worldsemi,ws2812-spi";
		status = "okay";

		/* SPI */
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(4)>;
		frame-format = <SPI_FRAME_FORMAT_TI>;

		/* WS2812 */
		chain-length = <2>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
	};
};

led_strip_spi_1: &spi4 {
	status = "okay";
	pinctrl-0 = <&spi4_default>;
	pinctrl-1 = <&spi4_sleep>;
	pinctrl-names = "default", "sleep";

	// Attach our LED strip to SPI1
	led_strip_1: ws2812_1@0 {
		compatible = "worldsemi,ws2812-spi";
		status = "okay";

		/* SPI */
		reg = <0>; /* ignored, but necessary for SPI bindings */
		spi-max-frequency = <DT_FREQ_M(4)>;
		frame-format = <SPI_FRAME_FORMAT_TI>;

		/* WS2812 */
		chain-length = <216>; /* arbitrary; change at will */
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
	};
};

/* FAT filesystem partition on the external QSPI flash, presented via USB Mass Storage.
 * Offset 0x12E000 within the MX25R64 device matches the PM fat_storage region.
 * The zephyr,flash-disk node wires this partition to the "NAND" disk driver so that
 * CONFIG_USB_MASS_STORAGE can expose it as a removable drive. */
/ {
	msc_disk0 {
		compatible = "zephyr,flash-disk";
		partition = <&fat_partition>;
		disk-name = "NAND";
		cache-size = <4096>;
	};
};

&qspi {
	status = "okay";
	pinctrl-0 = <&qspi_default>;
	pinctrl-1 = <&qspi_sleep>;
	pinctrl-names = "default", "sleep";

	/* MX25R6435F 64 Mbit QSPI NOR flash */
	mx25r64: mx25r6435f@0 {
		compatible = "nordic,qspi-nor";
		reg = <0>;
		/* proto0 has all 4 IO lines: use 4-bit read/write */
		writeoc = "pp4io";
		readoc = "read4io";
		sck-frequency = <8000000>;
		jedec-id = [c2 28 17];
		sfdp-bfp = [
			e5 20 f1 ff  ff ff ff 03  44 eb 08 6b  08 3b 04 bb
			ee ff ff ff  ff ff 00 ff  ff ff 00 ff  0c 20 0f 52
			10 d8 00 ff  23 72 f5 00  82 ed 04 cc  44 83 68 44
			30 b0 30 b0  f7 c4 d5 5c  00 be 29 ff  f0 d0 ff ff
		];
		size = <67108864>;
		has-dpd;
		t-enter-dpd = <10000>;
		t-exit-dpd = <35000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			/* App core secondary (upgrade) slot — used by MCUboot for DFU staging.
			 * Matches PM slot1_partition at 0x0, size 0xDC000 (shrunk in lockstep
			 * with mcuboot_primary when the coredump partition was carved from the
			 * end of internal flash, issue #80). */
			slot1_partition: partition@0 {
				label = "image-1";
				reg = <0x000000 0xDC000>;
			};

			/* slot2_partition is the net core's primary partition
			 * for image 2. It is defined in the net_core_sim_flash.overlay
			 * file, which is included in the net core build. It doesn't actually
			 * exist in flash that is accessible to the app core. Instead, we
			 * have a "virtual flash" driver that pretends to be flash, allowing
			 * the mcumgr code on the app core to "read" the net core's TLVs
			 */

			slot3_partition: partition@dc000 {
				label = "image-3";
				reg = <0xDC000 0x40000>;
			};

			/* NVS settings at 0x11c000 (PM settings_storage, 32 KB) are NOT mapped here.
			 * NCS replaces Zephyr's flash_map_default.c with flash_map_partition_manager.c,
			 * so FIXED_PARTITION_ID(storage_partition) already resolves to PM_SETTINGS_STORAGE_ID=9
			 * (the correct external-flash region). Adding a DTS node and pointing
			 * zephyr,settings-partition at it would switch settings_nvs.c to DT_FIXED_PARTITION_ID,
			 * which uses sequential DTS slot numbers that collide with PM IDs. */

			/* ~6.9 MB FAT partition — matches PM fat_storage region (0x124000, 0x6dc000);
			 * consumes all external flash after settings_storage (issue #80).
			 * Referenced by the msc_disk0 flash-disk node above. */
			fat_partition: partition@124000 {
				label = "fat-disk";
				reg = <0x124000 0x6dc000>;
			};
		};
	};
};

/* WARNING: these partition definitions do nothing because we are always building in multi-image mode, so we instead use Nordic's "Partition manager" */
&flash0 {
	status = "okay";
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0x00014200>;
		};
		/* The app core's primary slot (image-0) is at 0x14200, size 0xDBE00.
		 * This is the region that the app core boots from.
		 * It resides in the NRF5340's internal flash, and is used by MCUboot to
		 * store the main application image.
		 */
		slot0_partition: partition@14200 {
			label = "image-0";
			reg = <0x00014200 0x000DBE00>;
		};
	};
};

&ieee802154 {
	status = "okay";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";

	/* Add a USB UART device */
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
		/* label becomes this interface's USB iInterface string descriptor
		 * (see zephyr,cdc-acm-uart.yaml) -- distinguishes this COM port from
		 * cdc_acm_uart1 on the host instead of both showing up as a generic,
		 * duplicated class name (issue #107). */
		label = "RGB Sunglasses Proto0 - Shell";
	};

	cdc_acm_uart1: cdc_acm_uart1 {
		compatible = "zephyr,cdc-acm-uart";
		label = "RGB Sunglasses Proto0 - MCUMgr";
		/* hw-flow-control makes poll_out block instead of silently dropping bytes
		 * when the TX FIFO is full. Required for large SMP responses (taskstat etc.)
		 * that exceed the default 1024-byte FIFO before USB drains it.
		 * tx-fifo-size is set large enough to hold a full taskstat response (~2 KB)
		 * without ever needing to block. */
		hw-flow-control;
		tx-fifo-size = <4096>;
	};
};

/ {
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		sram0_image: image@20000000 {
			/* Zephyr image(s) memory */
		};

		sram0_s: image_s@20000000 {
			/* Secure image memory */
		};

		sram0_ns: image_ns@20040000 {
			/* Non-Secure image memory */
		};
	};
};

/* Retained memory for MCUboot blinfo shared data.
 * 256 bytes at the top of sram0_ns (0x2006ff00–0x20070000), excluded from BSS zeroing.
 * MCUboot writes its version here at boot; the app reads it via blinfo_lookup(). */
/ {
	sram_mcuboot_blinfo: sram@2006ff00 {
		compatible = "zephyr,memory-region", "mmio-sram";
		reg = <0x2006ff00 0x100>;
		zephyr,memory-region = "McubootRetainedMem";
		status = "okay";

		retainedmem {
			compatible = "zephyr,retained-ram";
			status = "okay";
			#address-cells = <1>;
			#size-cells = <1>;

			boot_info0: boot_info@0 {
				compatible = "zephyr,retention";
				status = "okay";
				reg = <0x0 0x100>;
			};
		};
	};

	chosen {
		zephyr,bootloader-info = &boot_info0;
	};
};

/* gpregret2 — one-byte retention register used as the BLE bootloader-updater
 * boot-mode flag.  The hook in fw/mcuboot_hooks/fprotect_hook.c writes
 * BOOT_MODE_UPDATER_ACTIVE (0xB2) here when it skips fprotect; the app
 * reads it back via bootmode_check() to confirm the region is writable.
 * gpregret1 is deliberately left free for generic NCS serial-recovery use. */
&gpregret2 {
	boot_mode_updater: boot_mode@0 {
		compatible = "zephyr,retention";
		status = "okay";
		reg = <0x0 0x1>;
	};
};

/ {
	chosen {
		zephyr,boot-mode = &boot_mode_updater;
	};
};

/* Include partition configuration file */
#include "rgb_sunglasses_proto0_nrf5340_cpuapp_partition_conf.dts"
