source "Kconfig.zephyr"

menu "Nordic Status Message GATT service sample"

config BT_STATUS_SECURITY_ENABLED
	bool "Enable security"
	default y
	select BT_SMP
	select BT_SETTINGS
	select FLASH
	select FLASH_PAGE_LAYOUT
	select FLASH_MAP
	select NVS
	select SETTINGS
	help
	  Enable BLE security implementation for Nordic Status Message instances.
	  After enabling this option one of the Status Messages would be available only when
	  connection is secure.

endmenu

config DUMP_DEVICE_REGISTERS
	bool "Enable dump device registers"
	default n
	help
	  Enable dumping of device registers.

config ANIMATION_MY_EYES
	bool "Enable My Eyes animation"
	default y
	help
	  Enable the My Eyes animation for the sunglasses.

config ANIMATION_RAINBOW
	bool "Enable Rainbow animation"
	default y
	help
	  Enable the Rainbow animation for the sunglasses.

config ANIMATION_ZIGZAG
	bool "Enable Zigzag animation"
	default y
	help
	  Enable the Zigzag animation for the sunglasses.

config ANIMATION_BEAT
	bool "Enable Beat animation"
	depends on AUDIO
	help
	  Enable the Beat animation. Requires CONFIG_AUDIO=y.
	  Flashes per-band column strips on each detected beat.

config ANIMATION_FFT_BARS
	bool "Enable FFT Bars animation"
	depends on AUDIO
	help
	  Enable the FFT Bars animation. Requires CONFIG_AUDIO=y.
	  Displays a live bar graph of the four frequency-band energies.

config ANIMATION_GLIM_PLAYER
	bool "Enable Glim Player animation"
	depends on FAT_FILESYSTEM_ELM
	default n
	help
	  Plays any .glim file found under /NAND:/glim on the 4 MB FAT partition
	  (Proto0 only). The file is picked via BLE (a generic "drop-down list"
	  characteristic) or a button press; looping behavior (loop one file,
	  play all files in sequence, or stop after one) is also BLE-selectable.
	  Use tools/convert_bad_apple.py / tools/convert_gif_to_glim.py to
	  generate .glim files. If no files are found, scrolls "NO FILE" as a
	  rainbow-colored error message.

config ANIMATION_MATRIX_CODE
	bool "Enable Matrix Code animation"
	default y
	help
	  Green waterfall dot animation inspired by The Matrix. Tunable drop
	  speed, fade time, column density, and color (default: phosphor green).

config IMU
	bool "Enable IMU subsystem (BMI270 accel/gyro pipeline)"
	depends on BMI270
	help
	  Enables a dedicated thread that reads accel+gyro frames from the BMI270
	  via the data-ready interrupt, then publishes them to a K_MSGQ so
	  animations can consume the data without knowing about the driver.
	  Proto0 only — the DK has no BMI270.

config IMU_THREAD_PRIORITY
	int "IMU thread priority"
	default 7
	depends on IMU
	help
	  Preemptive Zephyr priority for the IMU reader thread. Lower numbers run
	  first. Must be positive (preemptive) so the animation tick thread
	  (priority 6) can preempt it.

config IMU_THREAD_STACK_SIZE
	int "IMU thread stack size (bytes)"
	default 1024
	depends on IMU

config ANIMATION_TILT
	bool "Enable Tilt animation"
	depends on IMU
	help
	  Maps lateral accelerometer tilt (accel_x) to a hue-shifted rainbow
	  across the full display. Demonstrates the IMU animation pipeline.

config APP_PERSIST_BT_CONFIG
	bool "Persist BT-settable configuration via the Settings subsystem"
	default y
	depends on SETTINGS
	help
	  Backs every BT-settable config characteristic (core_config, animation
	  parameters/strings/colors, glim selection/loop mode, last-active
	  animation, extension animation parameters) with Zephyr's settings
	  subsystem so values survive a power cycle. See src/settings/ and
	  src/bluetooth/persistent_characteristic.h.
	  Disabled on rgb_sunglasses_dk (see its board .conf): that board's
	  internal-flash image slot has no spare room for this, and per
	  fw/CLAUDE.md it's legacy / doesn't get new features.

config APP_PERSIST_WORKQ_STACK_SIZE
	int "Stack size for the persistent-value-store workqueue"
	default 2048
	depends on APP_PERSIST_BT_CONFIG
	help
	  The persistent-value-store workqueue is used to debounce writes to
	  persistent config values (see src/settings/). This option controls the
	  stack size of that workqueue's thread.

config APP_BT_METADATA_CHARACTERISTIC
	bool "Append a bulk CUD/CPF metadata characteristic to every BtGattServer service"
	default y
	help
	  Adds one extra read-only characteristic per GATT service (see
	  BtGattServer in src/bluetooth/bt_service_cpp.h) that returns every
	  sibling characteristic's CUD name + CPF format in a single packed
	  blob, so the companion app can read it in one ATT round-trip instead
	  of two descriptor reads per characteristic during discovery (issue
	  #41 follow-up). Costs real flash: the blob duplicates every
	  characteristic's CUD description string as packed binary data.
	  Also covers extension animation services (src/extensions/extension_bt.cpp,
	  issue #90 follow-up) — built at runtime there instead of at compile
	  time, so it costs RAM (a few hundred bytes per extension slot) rather
	  than flash and is not part of the flash-budget reasoning below.
	  Disabled on rgb_sunglasses_dk (see its board .conf): that board's
	  internal-flash image slot has no spare room for this, and per
	  fw/CLAUDE.md it's legacy / doesn't get new features.

config APP_MCUBOOT_INFO_SERVICE
	bool "MCUboot version BLE service and shell command"
	default y
	depends on RETENTION_BOOTLOADER_INFO_TYPE_MCUBOOT
	help
	  Reads MCUboot's own version from the retained-SRAM TLV area written
	  at boot (BOOT_SHARE_DATA) and exposes it as a read-only BLE GATT
	  characteristic (McubootInfo service) and a Zephyr shell command
	  (mcuboot_version). Requires the zephyr,bootloader-info DTS chosen
	  node and the matching BOOT_SHARE_DATA Kconfig in the MCUboot image.
	  Disabled on rgb_sunglasses_dk (see its board .conf): DK is legacy
	  and doesn't get new features per fw/CLAUDE.md, and its internal-flash
	  image slot has no spare room for the blinfo stack.

config APP_MCUBOOT_UPDATER
	bool "BLE MCUboot bootloader updater (proto0 escape hatch)"
	default y if BOARD_RGB_SUNGLASSES_PROTO0_NRF5340_CPUAPP
	default n
	depends on FLASH && FLASH_MAP && APP_MCUBOOT_INFO_SERVICE
	help
	  Custom BLE-based mechanism to update the MCUboot bootloader in-field.
	  Receives the packaged binary over BLE, stores it in the external QSPI
	  staging partition, validates the CRC32, then page-by-page rewrites
	  internal flash 0x0-0x14000. Requires CONFIG_FPROTECT=n in the MCUboot
	  sysbuild conf so the SPU does not lock that region before jumping to the
	  app. Proto0 only — not offered on rgb_sunglasses_dk.

config APP_MCUBOOT_UPDATER_STACK_SIZE
	int "MCUboot updater worker thread stack size"
	default 4096
	depends on APP_MCUBOOT_UPDATER

config APP_MCUBOOT_UPDATER_INIT_PRIORITY
	int "MCUboot updater SYS_INIT priority"
	default 90
	depends on APP_MCUBOOT_UPDATER
	help
	  APPLICATION-phase init priority for the MCUboot updater. Must run
	  after the flash subsystem (pre-APPLICATION). The default of 90 leaves
	  room above CONFIG_MCUBOOT_INFO_INIT_PRIORITY (88).

config APP_SETTINGS_SAVE_DEBOUNCE_MS
	int "Debounce interval (ms) before persisting a changed config value"
	default 1000
	depends on SETTINGS
	help
	  How long to wait after the last write to a persistent config value
	  (see src/settings/) before flushing it to flash via the Settings
	  subsystem. Coalesces rapid successive writes (e.g. typing a text
	  string or dragging a color picker over BLE) into a single flash
	  write. This is app-owned and intentionally independent of
	  CONFIG_BT_SETTINGS_DELAYED_STORE_MS, which only governs Bluetooth's
	  own bonding/CCC storage.

config APP_WAKE_BUTTON
	bool "Enable the WAKE_N button input"
	default y
	help
	  Configures the wake button (sw-wake alias, shared with the BQ25792
	  /QON net) as a GPIO interrupt source. Disable on boards where the
	  WAKE_N line is defective: on proto0 the line reads stuck-low and,
	  with all 8 GPIOTE channels taken by other inputs, the wake pin falls
	  back to the SENSE/PORT-event mechanism — a misbehaving line there
	  produces an unbounded GPIOTE interrupt storm that starves every
	  thread (observed on 9V PD input, 2026-07-13).

config APP_TPS25750_CONFIG_9V
	bool "Use the 9V-capable TPS25750 config bundle"
	default n
	depends on TPS25750_INTERNAL_PATCH && !TPS25750_COMPRESSED_PATCH
	help
	  Selects misc/tps25750/tps25750-config-9v.c instead of the stock
	  5V-only bundle: identical ACT configuration except the sink
	  capabilities advertise a 9V PDO alongside 5V, letting the TPS25750
	  negotiate a 9V PD contract on capable chargers (the charger policy
	  then derives IINDPM/VINDPM from the contract; VAC_OVP headroom is
	  already programmed to 26V). Same byte size and symbol as the stock
	  bundle, so TPS25750_PATCH_HEADER_FILE is unchanged. NOTE: the
	  TPS25750 only accepts a patch in PTCH mode — after flashing, fully
	  power-cycle the board (USB AND battery removed) so the PD controller
	  reboots and downloads the new bundle.

config APP_CHARGER_POLICY
	bool "Charger policy engine (single owner of BQ25792 config writes)"
	default n
	depends on BQ25792 && TPS25750
	help
	  Central policy for the BQ25792 charger: disables the part's I2C
	  watchdog (whose expiry reverts EN_CHG/ICHG to POR defaults), gates
	  charge enable on battery presence (charging with no battery cycles
	  SYS to BATOVP per datasheet section 9.3.6 and brown-outs the system
	  — the proto0 no-battery reboot loop), programs VINDPM, and
	  reconciles the managed registers against external writers (the
	  TPS25750 config bundle shares the I2Cm port). Deliberately NOT
	  dependent on BT — gating must work on BLE-less builds. See
	  docs/plans/power-management-overhaul.md.

config APP_CHARGE_CURRENT_MA
	int "Default fast-charge current (ICHG) in mA"
	default 900
	range 50 5000
	depends on APP_CHARGER_POLICY
	help
	  ICHG target the charger policy programs at boot (BQ25792 REG03,
	  10mA resolution) and enforces via reconcile. Overridable at runtime
	  through the persisted BLE "Charge Current (mA)" characteristic and
	  the `power bq ichg` shell command; runtime values are clamped to
	  APP_CHARGE_CURRENT_MAX_MA. Chosen per battery pack — 900mA default
	  per the power plan. Note the TPS25750 config bundle re-programs
	  ICHG to its own value (500mA) on PD plug events; the policy
	  reconciles back within ~2s.

config APP_CHARGE_CURRENT_MAX_MA
	int "Maximum allowed fast-charge current in mA"
	default 2000
	range 50 5000
	depends on APP_CHARGER_POLICY
	help
	  Upper clamp for runtime (BLE/shell) charge-current requests —
	  protects the pack and wiring from a typo in the app. 2000mA matches
	  the chip's own 2S POR default.

config APP_INPUT_CURRENT_LIMIT_MAX_MA
	int "Maximum input current limit (IINDPM) in mA"
	default 3000
	range 100 3300
	depends on APP_CHARGER_POLICY
	help
	  Upper clamp on the IINDPM value the charger policy derives from the
	  negotiated PD contract / Type-C advertisement — bounds board input
	  wiring regardless of what a source offers. Legacy/unknown sources
	  are left on the BQ25792's own BC1.2-derived limit (unmanaged).

config APP_VINDPM_MV
	int "BQ25792 input voltage limit (VINDPM) in mV"
	default 4600
	range 3600 22000
	depends on APP_CHARGER_POLICY
	help
	  Absolute VINDPM threshold programmed at boot and enforced by the
	  charger policy's reconcile loop. 4600mV suits 5V-class sources
	  (above the 3600mV POR floor that lets a sagging source drag VBUS
	  down to unusable levels). PR C of the power plan derives this from
	  the negotiated PD contract voltage instead when a contract exists.

config APP_BATTERY_MONITOR
	bool "Battery monitoring BLE service"
	default n
	depends on BQ25792 && BT && APP_CHARGER_POLICY
	help
	  Exposes battery telemetry read from the BQ25792 charger's internal ADC
	  (battery voltage/current, VBUS voltage/current, charge status) as a
	  read/notify BLE GATT service, plus a persisted charging enable/disable
	  toggle (default ON; persistence requires APP_PERSIST_BT_CONFIG). Sampled
	  by the existing 500 ms charger status thread in src/power.cpp. Enabled
	  on rgb_sunglasses_proto0 via its board .conf; left off on
	  rgb_sunglasses_dk (legacy, no new features, flash budget — see
	  fw/CLAUDE.md).

config APP_POWER_DEBUG_SERVICE
	bool "Power Debug BLE service"
	default n
	depends on APP_BATTERY_MONITOR
	help
	  Read+notify debug telemetry for the power subsystem (power plan PR
	  E): input current limit readback (IINDPM), a power-state flag
	  bitmask (battery/VBUS presence, DPM regulation, watchdog expiry,
	  charge gating), the negotiated PD source type/budget, and the ICO
	  result. Fed by the charger status thread in src/power.cpp at the
	  reconcile cadence (~2s). Enabled on rgb_sunglasses_proto0 via its
	  board .conf; left off on rgb_sunglasses_dk (legacy, no new
	  features — see fw/CLAUDE.md).

config APP_USB_PRODUCT_STRING
	string "USB device product string"
	default "RGB Sunglasses"
	help
	  The USB Product string descriptor reported to the host (Device
	  Manager / lsusb / etc). Overridden per-board (see board .conf
	  files) to distinguish rgb_sunglasses_proto0 from
	  rgb_sunglasses_dk, mirroring CONFIG_BT_DEVICE_NAME.

config APP_EXTENSION_HOST
	bool "Sandboxed LLEXT animation extension host"
	depends on LLEXT && USERSPACE && FAT_FILESYSTEM_ELM
	default n
	help
	  Discovers .llext animation extensions on /NAND:/ext at boot, loads
	  them via the llext filesystem loader, and executes their code
	  exclusively on a dedicated K_USER thread confined to a per-extension
	  memory domain (issue #85). The kernel-side pattern controller
	  exchanges data with the extension purely through the extension's own
	  exported globals (see include/rgbx/rgbx_api.h), enforcing a per-tick
	  deadline with abort/recreate/fallback recovery. Proto0 only — the DK
	  has neither LLEXT nor USERSPACE enabled.

config APP_EXT_HOST_THREAD_PRIORITY
	int "Extension host thread priority"
	default 7
	depends on APP_EXTENSION_HOST
	help
	  Preemptive Zephyr priority for the sandboxed extension thread. Must
	  be numerically greater than the pattern controller thread (priority
	  6) so a runaway extension can always be preempted by the thread that
	  enforces its deadline.

config APP_EXT_HOST_STACK_SIZE
	int "Extension host thread stack size (bytes)"
	default 2048
	depends on APP_EXTENSION_HOST

config APP_EXT_TICK_DEADLINE_MS
	int "Extension tick deadline (ms)"
	default 50
	depends on APP_EXTENSION_HOST
	help
	  How long the pattern controller waits for the sandboxed extension to
	  finish one tick before declaring it hung, aborting the host thread,
	  and falling back (issue #85 recovery path).

config STATUS_LED
	bool "Onboard status LED module (led_strip_2)"
	depends on LED_STRIP && WS2812_STRIP_SPI
	default n
	help
	  Drives the two onboard WS2812 status LEDs (led_strip_2) from a
	  dedicated thread with solid, blinking, and breathing animations.
	  When enabled, led_controller does not manage led_strip_2.

config NETCORE_VERSION_IPC
	bool "Query running net core version via IPC"
	depends on IPC_SERVICE
	help
	  Registers an IPC endpoint (NETCORE_VER) on ipc0 at startup.
	  The net core responds with its running firmware version and
	  SHA256 hash; the result is cached and surfaced through the
	  net_core_sim_flash driver so MCUMgr img_list reports real data.

if NETCORE_VERSION_IPC

module = NETCORE_VERSION
module-str = "netcore_version"
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif # NETCORE_VERSION_IPC

config MCUBOOT_INFO_INIT_PRIORITY
	int "MCUboot info service init priority"
	default 88
	help
	  The init priority of the MCUboot info service. Lower numbers are
	  initialized first. The default is 88, which is one-higher than CONFIG_RETENTION_BOOTLOADER_INFO_INIT_PRIORITY.

rsource "drivers/Kconfig"